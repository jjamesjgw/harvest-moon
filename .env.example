# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. Production values live in the Vercel project.

# ─── Supabase (client) ───────────────────────────────────────────────
# Bundled into the browser. The anon key is safe to expose because all
# data access goes through RLS — but only if your policies are tight.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Logical league identifier. Defaults to "harvest-moon" if unset.
# Multi-league deployments override per-environment.
NEXT_PUBLIC_LEAGUE_ID=harvest-moon

# ─── Supabase (server) ───────────────────────────────────────────────
# Used by Next.js Route Handlers under app/api/. Never expose to the
# client; this key bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Web Push (VAPID) ────────────────────────────────────────────────
# Generate a keypair with: npx web-push generate-vapid-keys
# The public key is also exposed to the browser via NEXT_PUBLIC_*.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=B...
VAPID_PUBLIC_KEY=B...
VAPID_PRIVATE_KEY=...
# Contact for push services (mailto: or https:). Defaults to a placeholder.
VAPID_SUBJECT=mailto:you@example.com

# ─── Session signing ─────────────────────────────────────────────────
# HMAC key used to sign the hm_session cookie issued by /api/auth/login.
# Must be at least 32 chars. Rotating this invalidates every live session
# (everyone has to sign in again), so treat as long-lived.
SESSION_SECRET=generate-a-long-random-string

# ─── API route secrets ───────────────────────────────────────────────
# Shared secret required by /api/notify (push fan-out).
NOTIFY_SECRET=generate-a-long-random-string

# Shared secret required by /api/ingest-results when invoked manually.
INGEST_SECRET=generate-a-long-random-string

# Shared secret expected by /api/ingest-results when called by Vercel Cron.
# See vercel.json for the cron schedule.
CRON_SECRET=generate-a-long-random-string
